# Dalux Build connection (server-side only; never expose the API key to clients)
DALUX_BASE_URL=https://<your-company>.dalux.com/api
DALUX_API_KEY=replace-with-your-api-key

# Webhook signature verification.
# The exact header name and scheme are not part of the public OpenAPI spec
# (docs/official-api-docs/Dalux Build API.yaml has no webhook definitions),
# so configure them to match what Dalux sends you. Leave the secret empty to
# disable verification (NOT recommended outside local testing).
DALUX_WEBHOOK_SECRET=
DALUX_WEBHOOK_SIGNATURE_HEADER=X-Dalux-Signature

# Where the watch list lives (JSON; see watchlist.example.json).
WATCHLIST_PATH=./watchlist.json

# Local state: last-seen revision per file + processed event ids (SQLite file).
STATE_DB_PATH=./state.sqlite3

# Directory where changed files (and their .dalux.json sidecars) are written.
DOWNLOAD_DIR=./downloads

# Outbound QA trigger. Set at most one.
# 1) HTTP POST a JSON body to this URL (e.g. CI webhook, queue ingest).
QA_WEBHOOK_URL=
# Optional bearer token sent as Authorization header on the QA webhook.
QA_WEBHOOK_TOKEN=
# 2) Run a local command; the event JSON is passed on stdin.
QA_COMMAND=

# HTTP server bind address.
HOST=0.0.0.0
PORT=8000
